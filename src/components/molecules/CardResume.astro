---
 interface Props {
    rangoYear: string
    title:string
    subtitle:string
    text:string
 }

 const {rangoYear,title,subtitle,text}= Astro.props as Props
---
<div class="card">
    <span class="bg-resalt">{rangoYear}</span>
    <h3 class="card__title">{title}</h3>
    <h4 class="card__subtitle">{subtitle}</h4>
    <p class="card__description">{text}</p> 
</div>

<style scoped>
    .card{
		@apply my-5 rounded-[2.4rem] border border-gris-200 bg-white p-7 shadow-[0_14px_35px_rgba(15,23,42,0.05)];
	}
	.bg-resalt{
		@apply mb-4 inline-flex rounded-full bg-[#edf8f3] px-4 py-2 text-[1.2rem] font-semibold uppercase tracking-[0.08em] text-tertiary;
	}

	.card__title{
		@apply mb-2 text-[2.1rem] font-semibold text-secondary;
	}
	.card__subtitle{
		@apply mb-3 text-[1.55rem] font-medium text-[#0f8f6d];
	}
	.card__description {
		@apply text-[1.5rem] leading-relaxed text-gris-300;
	}
</style>
