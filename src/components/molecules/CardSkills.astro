---
import type { ISkills } from '@interface/home';
import Tumb from '@atoms/Thumb.astro';

const { name, value, title, image } = Astro.props as ISkills;

const getLevelLabel = (score: number) => {
	if (score >= 88) return 'Avanzado';
	if (score >= 75) return 'Intermedio alto';
	return 'Intermedio';
};

const experienceMap: Record<string, string> = {
	html: 'Maquetación semántica',
	css: 'UI responsive',
	javascript: 'Lógica e interacción',
	typescript: 'Tipado y escalabilidad',
	tailwind: 'Diseño utilitario',
	postcss: 'Flujo de estilos',
	react: 'Experiencia profesional',
	vue: 'Proyectos y aprendizaje',
	astro: 'Sitios rápidos',
	next: 'Apps y SSR',
	git: 'Trabajo colaborativo',
	node: 'APIs y backend',
	nest: 'Arquitectura backend',
	angular: 'Experiencia profesional',
};

const levelLabel = getLevelLabel(value);
const experienceLabel = experienceMap[name] ?? 'Desarrollo web';
---

<div class='SkillCard'>
	<div class='SkillCard__icon'>
		<Tumb className='h-full w-full px-1 py-2' contain img={image} />
	</div>
	<div class='Skill'>
		<div class='Skill__description'>
			<p class='Skill__title'>{title}</p>
			<span class='Skill__level'>{levelLabel}</span>
		</div>
		<p class='Skill__context'>{experienceLabel}</p>
	</div>
</div>

<style>
	.SkillCard {
		@apply flex items-center gap-4 rounded-[2rem] border border-gris-200 bg-white px-4 py-4 shadow-[0_14px_30px_rgba(15,23,42,0.04)];
	}

	.SkillCard__icon {
		@apply flex h-[5.6rem] w-[5.6rem] shrink-0 items-center justify-center rounded-[1.6rem] bg-[#f4faf7];
	}

	.Skill {
		@apply w-full;
	}
	.Skill__description {
		@apply mb-3 flex justify-between;
	}

	.Skill__title {
		@apply text-[1.5rem] font-semibold text-secondary;
	}

	.Skill__level {
		@apply rounded-full bg-[#edf8f3] px-3 py-1 text-[1.15rem] font-semibold uppercase tracking-[0.08em] text-tertiary;
	}

	.Skill__context {
		@apply text-[1.35rem] text-gris-300;
	}
</style>
