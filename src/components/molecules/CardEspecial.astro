---
interface Props {
	title: string;
	text: string;
	icon: string;
}
const {title,text,icon} = Astro.props as Props;
---

<div class='CardEspecial'>
	<div class={`logo ${icon.includes('display') ? 'logo--display' : ''} ${icon.includes('phone') ? 'logo--phone' : ''} ${icon.includes('bag') ? 'logo--bag' : ''} ${icon.includes('people') ? 'logo--people' : ''} ${icon.includes('megaphone') ? 'logo--megaphone' : ''}`}>
		<div class='logo__inner'>
			<i class={icon}/>
		</div>
	</div>
	<div class='content'>
		<h2>{title}</h2>
		<p>{text}</p>
	</div>
</div>

<style>
    .CardEspecial{
        @apply flex gap-5 rounded-[2.4rem] border border-gris-200 bg-white px-6 py-7 shadow-[0_18px_40px_rgba(15,23,42,0.05)] transition-transform duration-300 hover:-translate-y-1;
    }

    .logo{
        @apply relative flex h-[7rem] w-[7rem] shrink-0 items-center justify-center rounded-[2rem] bg-[#eef8f3] text-tertiary;
    }

    .logo__inner {
        @apply flex h-full w-full items-center justify-center;
    }

    .logo i {
        @apply text-[2.8rem];
    }

    .logo--display i {
        @apply text-[3.1rem];
    }

    .logo--phone i {
        @apply text-[2.65rem];
    }

    .logo--bag i {
        @apply text-[2.75rem];
    }

    .logo--people i {
        @apply text-[2.7rem];
    }

    .logo--megaphone i {
        @apply text-[2.7rem];
    }

    .content{
        @apply pt-1;
        h2{
            @apply mb-3 text-[2rem] font-semibold text-secondary;
        }
        p{
            @apply text-[1.55rem] leading-relaxed text-gris-300
        }

    }

</style>
