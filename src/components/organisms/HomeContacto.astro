---
import Container from '@globals/Container.astro';
import Title from '@atoms/Title.astro';
import Button from '@atoms/Button.astro';
import { getGenerals } from '@/src/lib/getGenerals';
import cv from '@/src/assets/docs/CV - Jhair Infanzon.pdf';

const { infogeneral } = getGenerals();
const whatsappLink = `https://wa.me/${infogeneral.phone.replace(/\D/g, '')}?text=Hola%20Jhair,%20quiero%20hablar%20sobre%20un%20proyecto%20web.`;

const contactCards = [
	{
		title: 'Email',
		value: infogeneral.email,
		href: `mailto:${infogeneral.email}`,
		icon: 'bi bi-envelope-fill'
	},
	{
		title: 'WhatsApp',
		value: infogeneral.phone,
		href: whatsappLink,
		icon: 'bi bi-whatsapp'
	},
	{
		title: 'Ubicacion',
		value: infogeneral.city,
		href: 'https://www.google.com/maps/place/Lima,+Peru',
		icon: 'bi bi-geo-alt-fill'
	}
];

const process = [
	'Entendemos el objetivo del proyecto y el tipo de cliente al que quieres llegar.',
	'Definimos una estructura clara para contenido, navegacion y llamadas a la accion.',
	'Diseño y desarrollo una interfaz responsive lista para publicar y escalar.'
];
---

<Container id='contact' class='Content-contacto'>
	<Title title='Conversemos sobre tu proyecto' subtitle='Contacto' />

	<div class='contactGrid'>
		<section class='contactIntro'>
			<span class='contactLabel'>Disponible para nuevos proyectos</span>
			<h3>Si necesitas una web profesional, podemos empezar por una conversación clara.</h3>
			<p>
				Trabajo con clientes que necesitan mejorar su presentación digital, lanzar una
				landing, renovar su sitio o construir una experiencia frontend más sólida.
			</p>

			<div class='contactActions'>
				<Button url={whatsappLink} class='contactPrimary'>Escribirme por WhatsApp</Button>
				<Button url={cv} class='contactSecondary'>Ver CV</Button>
			</div>
		</section>

		<section class='contactCards'>
			{
				contactCards.map(({ title, value, href, icon }) => (
					<a href={href} target='_blank' class='contactCard'>
						<div class='contactCard__icon'>
							<i class={icon}></i>
						</div>
						<div>
							<p class='contactCard__title'>{title}</p>
							<p class='contactCard__value'>{value}</p>
						</div>
					</a>
				))
			}
		</section>
	</div>

	<section class='contactProcess'>
		<div class='contactProcess__header'>
			<h3>Cómo suelo trabajar</h3>
			<p>
				Mi objetivo es que el proceso sea simple, ordenado y orientado a resultados,
				sin complicar la toma de decisiones.
			</p>
		</div>
		<div class='contactProcess__grid'>
			{
				process.map((item, index) => (
					<article class='processCard'>
						<span>0{index + 1}</span>
						<p>{item}</p>
					</article>
				))
			}
		</div>
	</section>
</Container>

<style scoped>
	.Content-contacto {
		@apply py-[4rem];
	}

	.contactGrid {
		@apply grid gap-8 laptop:grid-cols-[1fr_0.9fr];
	}

	.contactIntro {
		@apply rounded-[3rem] bg-secondary px-7 py-8 text-white;
	}

	.contactLabel {
		@apply text-[1.2rem] uppercase tracking-[0.16em] text-tertiary;
	}

	.contactIntro h3 {
		@apply mt-4 text-[3.2rem] font-semibold leading-tight;
	}

	.contactIntro p {
		@apply mt-5 text-[1.7rem] leading-relaxed text-white/70;
	}

	.contactActions {
		@apply mt-8 flex flex-wrap gap-4;
	}

	.contactPrimary,
	.contactSecondary {
		@apply !px-8 !py-5;
	}

	.contactSecondary {
		@apply !bg-white/10 hover:!bg-white/20;
	}

	.contactCards {
		@apply grid gap-5;
	}

	.contactCard {
		@apply flex items-center gap-5 rounded-[2.4rem] border border-gris-200 bg-[#fbfbf8] px-6 py-6 transition-transform duration-300;
	}

	.contactCard:hover {
		transform: translateY(-3px);
	}

	.contactCard__icon {
		@apply flex h-[5.8rem] w-[5.8rem] items-center justify-center rounded-[1.8rem] bg-secondary text-[2.2rem] text-tertiary;
	}

	.contactCard__title {
		@apply text-[1.2rem] uppercase tracking-[0.14em] text-gris-100;
	}

	.contactCard__value {
		@apply mt-2 text-[1.8rem] font-medium text-secondary;
	}

	.contactProcess {
		@apply mt-12 rounded-[3rem] border border-gris-200 bg-[#fbfbf8] px-6 py-8 laptop:px-10;
	}

	.contactProcess__header {
		@apply max-w-[70rem];
	}

	.contactProcess__header h3 {
		@apply text-[2.8rem] font-semibold text-secondary;
	}

	.contactProcess__header p {
		@apply mt-3 text-[1.6rem] leading-relaxed text-gris-300;
	}

	.contactProcess__grid {
		@apply mt-8 grid gap-5 tablet:grid-cols-3;
	}

	.processCard {
		@apply rounded-[2.2rem] border border-gris-200 bg-white px-5 py-5;
	}

	.processCard span {
		@apply text-[1.2rem] font-semibold uppercase tracking-[0.14em] text-tertiary;
	}

	.processCard p {
		@apply mt-3 text-[1.55rem] leading-relaxed text-gris-300;
	}
</style>
