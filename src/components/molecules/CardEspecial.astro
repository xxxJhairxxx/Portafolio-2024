---
interface Props {
	title: string;
	text: string;
    icon: string;
}
const {title,text,icon} = Astro.props as Props;
---

<div class='CardEspecial'>
	<div class='logo'>
		<i class={icon}/>
	</div>
	<div class='content'>
		<h2>{title}</h2>
		<p>{text}</p>
	</div>
</div>

<style scoped>
    .CardEspecial{
        @apply flex h-full flex-col gap-6 rounded-[2.4rem] border border-gris-200 bg-[#fbfbf8] px-6 py-8 shadow-[0_16px_35px_rgba(15,23,42,0.06)] transition-transform duration-300;
    }

	.CardEspecial:hover {
		transform: translateY(-4px);
	}

    .logo{
        @apply flex h-[6.4rem] w-[6.4rem] items-center justify-center rounded-[1.8rem] bg-secondary text-[3rem] text-tertiary;
    }

    .content{
        h2{
            @apply text-[2.1rem] font-semibold text-secondary;
        }
        p{
            @apply mt-3 text-[1.55rem] leading-relaxed text-gris-300;
        }
    }

</style>
