---
import Container from '@globals/Container.astro';
import Title from '@atoms/Title.astro';
import CardResume from '@molecules/CardResume.astro';
import Button from '@atoms/Button.astro';
import type { IHomeResume, IResume } from '@interface/home';
import cv from '@/src/assets/docs/CV - Jhair Infanzon.pdf';

interface Props {
	homeResume: IHomeResume;
	studies: IResume[];
	experience: IResume[];
}

const { homeResume, studies, experience } = Astro.props as Props;
---

<Container class='Resume' id='resume'>
	<Title title={homeResume.title} subtitle={homeResume.subtitle} />

	<div class='Resume__lead'>
		<p>
			Mi experiencia combina trabajo en producto, desarrollo de interfaces y proyectos
			comerciales para distintos tipos de cliente. Esta mezcla me ayuda a resolver con
			mayor criterio tanto lo visual como lo funcional.
		</p>
	</div>

	<section class='Resume-details'>
		<div class='Resume-Experience'>
			<h2>Experiencia profesional</h2>
			{
				experience.map((props) => (
					<CardResume {...props} />
				))
			}
		</div>
		<div class='Resume-Estudios'>
			<h2>Formacion</h2>
			{
				studies.map(({ rangoYear, title, subtitle, text }) => (
					<CardResume
						rangoYear={rangoYear}
						title={title}
						subtitle={subtitle}
						text={text}
					/>
				))
			}
		</div>
	</section>

	<Button url={cv} class='mx-auto mt-8 flex text-[1.6rem] gap-3'>
		Descargar CV <i class='bi bi-download'/>
	</Button>
</Container>

<style>
	.Resume {
		@apply py-[4rem];
	}

	.Resume__lead {
		@apply mx-auto mb-12 max-w-[72rem] text-center;
	}

	.Resume__lead p {
		@apply text-[1.7rem] leading-relaxed text-gris-300 laptop:text-[1.9rem];
	}

	.Resume-details {
		@apply grid gap-8 laptop:grid-cols-2;
	}

	.Resume-Estudios,
	.Resume-Experience {
		@apply flex flex-col;
	}

	.Resume-Estudios h2,
	.Resume-Experience h2 {
		@apply mb-4 text-[2.6rem] font-semibold text-secondary;
	}
</style>
