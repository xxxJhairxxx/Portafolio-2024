<style scoped>
	.Content-contacto {
		@apply flex w-full flex-col gap-10;
	}

	.contactLayout {
		@apply grid w-full gap-6;
	}

	.contactoHero {
		@apply flex w-full flex-col gap-5 rounded-[2.8rem] border border-gris-200 bg-white p-8 shadow-[0_18px_40px_rgba(15,23,42,0.05)];
	}

	.contactoHero__eyebrow {
		@apply w-fit rounded-full bg-[#edf8f3] px-5 py-3 text-[1.2rem] font-semibold uppercase tracking-[0.14em] text-tertiary;
	}

	.contactoHero h3 {
		@apply max-w-[18ch] text-[3.2rem] font-semibold leading-tight text-secondary;
	}

	.contactoHero p {
		@apply max-w-[62rem] text-[1.7rem] leading-relaxed text-gris-300;
	}

	.contactoHero__points {
		@apply grid gap-3 text-[1.5rem] text-secondary;
	}

	.contactoHero__points li {
		@apply relative pl-6 leading-relaxed;
	}

	.contactoHero__points li::before {
		@apply absolute left-0 top-[0.7rem] h-[0.8rem] w-[0.8rem] rounded-full bg-tertiary;
		content: '';
	}

	.contactoHero__actions {
		@apply flex flex-wrap items-center gap-4 pt-2;
	}

	.contactoHero__button {
		@apply px-8 py-4 text-[1.5rem];
	}

	.contactoHero__link {
		@apply text-[1.5rem] font-semibold text-secondary underline decoration-tertiary decoration-2 underline-offset-4;
	}

	.contacto-info {
		@apply grid w-full gap-6;
		.contacto-info-address {
			@apply flex flex-col justify-center items-center;

			.contacto__text {
				@apply w-full text-center;
			}
		}
	}

	.contactCard {
		@apply w-full rounded-[2.4rem] border border-gris-200 bg-white px-6 py-6 shadow-[0_14px_34px_rgba(15,23,42,0.04)];
	}

	.contactoCard--highlight {
		@apply border-tertiary/20 bg-[#f8fbf9];
	}

	.contacto__link {
		@apply transition-colors;
	}

	.contacto__link:hover {
		@apply text-tertiary;
	}

	.sigueme {
		@apply flex flex-col gap-4 text-center text-[1.7rem];
		color: #4c4d4d;
	}

	.Logo-redes {
		@apply flex justify-center;
	}

	.Logo-redes :global(.network) {
		@apply ml-0 w-auto gap-5 text-[2.2rem] text-gris-100;
	}

	.contacto__title {
		@apply pb-2 text-[1.25rem] font-semibold uppercase tracking-[0.12em] text-tertiary;
	}

	.contacto__text {
		@apply text-[1.55rem] leading-relaxed text-gris-100;
	}

	.contacto__meta {
		@apply pt-2 text-[1.35rem] leading-relaxed text-gris-300;
	}

	@screen laptop {
		.Content-contacto {
			@apply w-[120rem];
		}
		.contactLayout {
			@apply grid-cols-[minmax(0,1.1fr)_minmax(32rem,0.9fr)] items-start gap-8;
		}
		.contacto-info {
			@apply h-full items-start justify-start;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			.contacto-info-address {
				@apply items-start;
				.contacto__text {
					@apply mt-0 text-start text-[1.6rem];
				}
			}
			.sigueme {
				@apply items-start;
			}
		}
		.contactCard:last-child {
			@apply col-span-2;
		}
	}
</style>
