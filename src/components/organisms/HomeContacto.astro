---
import Container from '@globals/Container.astro';
import Title from '@atoms/Title.astro';
import Button from '@atoms/Button.astro';
---

<Container id='contact' class='Content-contacto'>
	<Title title='Contacto' subtitle='Contratos' className='col-span-2 laptop:order-1' />

	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const form = document.querySelector('.Formulario') as HTMLFormElement | null;
			if (!form) return;

			form.addEventListener('submit', (event) => {
				event.preventDefault();
				const formData = new FormData(form);
				const name = String(formData.get('name') ?? '').trim();
				const email = String(formData.get('email') ?? '').trim();
				const message = String(formData.get('message') ?? '').trim();

				const subject = encodeURIComponent(`Nuevo mensaje de ${name || 'tu portafolio'}`);
				const body = encodeURIComponent(
					`Nombre: ${name}\nEmail: ${email}\n\nMensaje:\n${message}`
				);

				window.location.href = `mailto:jinfanzonquispe30@gmail.com?subject=${subject}&body=${body}`;
			});
		});
	</script>

	<form class='Formulario'>
		<h3 class='for__title'>ESCRIBENOS</h3>

		<input type='text' name='name' placeholder='Nombre' class='input' required />
		<input type='email' name='email' placeholder='email' class='input' required />
		<textarea class='message' name='message' placeholder='Cuentanos sobre lo que necesitas...'
			required
		></textarea>
		<Button class='mx-auto w-fit py-3 px-8 col-span-2 laptop:px-8 laptop:py-4 laptop:text-[1.5rem]'>Enviar Mensaje </Button>
	</form>
	<div class='contacto-info'>
		<div class='contacto-info-address'>
			<h3 class='contacto__title'>DIRECCION</h3>
			<p class='contacto__text'>
				4th Floor, Plot No.22, 145 Murphy Canyon Rd. San Diego CA 2028
			</p>
		</div>

		<ul class='contacto__skills'>
			<li class='contacto__items'>
				<i class='bi bi-phone-fill con'></i> +51 922 692 354
			</li>
			<li class='contacto__items mail'>
				<i class='bi bi-envelope-fill con'></i>
				<a href='mailto:jinfanzonquispe30@gmail.com'>jinfanzonquispe30@gmail.com</a>
			</li>
		</ul>
		<div class='sigueme'>
			<h3 class='contacto__title'>SIGUEME</h3>
			<div class='Logo-redes'>
				<i class='bi bi-facebook conx'></i>
				<i class='bi bi-twitter conx'></i>
				<i class='bi bi-github conx'></i>
				<i class='bi bi-linkedin conx'></i>
			</div>
		</div>
	</div>
</Container>

<style scoped>
	.Content-contacto {
		@apply flex flex-col items-center w-full gap-10;
	}
	.contacto-info {
		@apply w-full flex flex-col items-center justify-center gap-10;
		line-height: 30px;
		.contacto-info-address {
			@apply flex flex-col justify-center items-center;

			.contacto__text {
				color: #4c4d4d;
				@apply text-center w-[68%];
			}
		}
	}

	.contacto__skills {
		@apply flex flex-col;
		align-items: center;
		list-style: none;
		color: #4c4d4d;
	}

	.contacto__items a {
		@apply text-gris-100 transition-colors;
	}

	.contacto__items a:hover {
		@apply text-tertiary;
	}

	.sigueme {
		@apply w-[80%] text-[1.7rem] flex flex-col gap-4 text-center;
		color: #4c4d4d;
	}

	.Logo-redes {
		display: flex;
		justify-content: space-around;
	}

	.conx {
		font-size: 25px;
		color: #4c4d4d;
		cursor: pointer;
	}

	.Formulario {
		@apply w-full grid grid-cols-2 gap-5;
	}
	.for__title {
		@apply text-[1.7rem] col-span-2;
		width: 100%;
		color: #181818;
		font-weight: 600;
		margin-bottom: 10px;
	}

	.input {
		@apply w-full col-span-2 px-[1.5rem] py-[0.7rem];
		margin-right: auto;
		border-radius: 10px;
		border: 1px solid #aaaaaa;
	}
	.message {
		@apply w-full h-[15rem] col-span-2  px-[1.5rem] py-[0.7rem];
		border-radius: 10px;
		border: 1px solid #aaaaaa;
	}

	.bi-github:hover {
		color: #000;
	}
	.contacto__title {
		@apply py-2;
		font-weight: 600;
		color: black;
	}

	@screen laptop {
		.Content-contacto {
			@apply items-center w-[120rem] gap-10 grid grid-cols-2;
		}
		.contacto-info {
			@apply order-2 justify-start items-start h-full;
			.contacto-info-address {
				@apply items-start;
				.contacto__text {
					@apply text-start mt-5 text-[1.7rem];
				}
			}
			.contacto__skills {
				@apply flex flex-col items-start text-[1.7rem];
			}
			.sigueme {
				@apply items-start;

				.Logo-redes {
					@apply gap-12;
				}
			}
		}
		.Formulario {
			@apply order-3;
			.input {
				@apply col-span-1 px-[7%] py-[4%] text-[1.7rem];
			}
			.message {
				@apply px-[3%] py-[3%]  text-[1.7rem] col-span-2;
			}
		}
	}
</style>
