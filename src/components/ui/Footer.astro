---
import { getGenerals } from '@/src/lib/getGenerals';

const { footer } = getGenerals();
---

<footer class='footer'>
	<div class='footer__copy' set:html={footer.text} />
</footer>

<style scoped>
	.footer {
		@apply border-t border-gris-200 bg-white px-[6%] py-8;
	}

	.footer__copy {
		@apply mx-auto flex max-w-[124rem] flex-col gap-2 text-center text-[1.4rem] text-gris-100;
		.resalt {
			@apply text-tertiary;
		}
	}
</style>
