---
 interface Props {
    rangoYear: string
    title:string
    subtitle:string
    text:string
 }

 const {rangoYear,title,subtitle,text}= Astro.props as Props
---
<div class="card">
    <span class="bg-resalt">{rangoYear}</span>
    <h3 class="card__title">{title}</h3>
    <h4 class="card__subtitle">{subtitle}</h4>
    <p class="card__description">{text}</p> 
</div>

<style scoped>
    .card{
		@apply mb-5 rounded-[2.2rem] border border-gris-200 bg-white px-6 py-6 shadow-[0_12px_28px_rgba(15,23,42,0.05)];
	}
	.bg-resalt{
		@apply inline-flex rounded-full bg-tertiary px-4 py-2 text-[1.2rem] font-semibold uppercase tracking-[0.08em] text-white;
	}

	.card__title{
		@apply mt-4 text-[2.2rem] font-semibold text-secondary;
	}
	.card__subtitle{
		@apply mb-3 mt-2 text-[1.5rem] font-medium text-tertiary;
	}
	.card__description {
		@apply text-[1.55rem] leading-relaxed text-gris-300;
	}
</style>
