---
import type { ISkills } from '@interface/home';
import Tumb from '@atoms/Thumb.astro';

const { value, title,image } = Astro.props as ISkills;
---

<div class='SkillCard'>
	<div class='Skill'>
		<div class='Skill__description'>
			<p class='Skill__title'>{title}</p>
			<p class='porcentaje__num'>{value}%</p>
		</div>
		<div class='Skill__barra'>
			<div class='porcentaje__bar' style={{ width: `${value}%` }}></div>
		</div>
	</div>
    <Tumb className='h-[5.4rem] w-[5.4rem] rounded-[1.4rem] bg-white px-2 py-2' contain img={image}>
</div>

<style>
	.SkillCard {
		@apply flex items-center gap-4 rounded-[2rem] border border-gris-200 bg-white px-5 py-5 shadow-[0_10px_24px_rgba(15,23,42,0.05)];
	}
	.Skill {
		width: 100%;
	}
	.Skill__description {
		@apply mb-3 flex justify-between;
	}
	.Skill__title,
	.porcentaje__num {
		@apply text-[1.5rem] font-medium text-secondary;
	}

	.Skill__barra {
		width: 100%;
		background-color: #d9dfdf;
		height: 8px;
		border-radius: 999px;
		overflow: hidden;
	}
	.porcentaje__bar {
		background-color: #20c983;
		height: 8px;
		border-radius: 999px;
	}
</style>
